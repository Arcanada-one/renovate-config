{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "group:allNonMajor",
    "helpers:pinGitHubActionDigests",
    ":gitSignOff"
  ],
  "timezone": "UTC",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Require manual approval for major bumps — semver-major can carry breaking changes across the ecosystem.",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Auto-merge patch/minor devDependency updates once CI is green — low blast radius.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "GitHub Actions pinned to commit SHA per S4 supply-chain rule — group into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true
    }
  ]
}
